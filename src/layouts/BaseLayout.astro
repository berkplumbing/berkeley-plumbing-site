---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;

const schema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  "name": "Berkeley Plumbing",
  "description": "C-36 licensed plumbing contractor specializing in new construction, custom remodels, and ADUs in the Conejo Valley.",
  "url": "https://berkeleyplumbingca.com",
  "telephone": "(310) 733-7808",
  "email": "berkplumbing@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "839 Jenny Dr",
    "addressLocality": "Newbury Park",
    "addressRegion": "CA",
    "postalCode": "91320",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "34.1733",
    "longitude": "-118.9119"
  },
  "areaServed": [
    "Newbury Park", "Agoura Hills", "Thousand Oaks",
    "Westlake Village", "Calabasas", "Oak Park", "Moorpark"
  ],
  "hasCredential": [
    {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "license",
      "name": "CSLB C-36 Plumbing Contractor License",
      "identifier": "1115151"
    }
  ],
  "sameAs": [
    "https://www.yelp.com/biz/berkeley-plumbing-agoura-hills"
  ],
  "priceRange": "$$"
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Berkeley Plumbing" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Favicon placeholder -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-VX9D0C2937"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-VX9D0C2937');
  </script>
</head>
<body class="bg-white font-body text-slate-800 antialiased">
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
