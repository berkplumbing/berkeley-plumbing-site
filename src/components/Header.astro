---
const nav = [
  { label: 'Services', href: '/services/new-construction/' },
  { label: 'Remodels & ADUs', href: '/services/remodels-adu/' },
  { label: 'Service Areas', href: '/service-areas/newbury-park/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-navy-900 sticky top-0 z-50 shadow-md">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-18">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="Berkeley Plumbing home">
        <svg class="w-8 h-8 text-copper flex-shrink-0" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2"/>
          <path d="M10 22 L10 14 Q10 10 14 10 L18 10 Q22 10 22 14 Q22 18 18 18 L14 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <circle cx="14" cy="18" r="1.5" fill="currentColor"/>
        </svg>
        <div>
          <span class="text-white font-display font-semibold text-lg leading-none tracking-wide">Berkeley Plumbing</span>
          <span class="block text-copper text-xs font-body font-medium tracking-wider uppercase mt-0.5">CSLB #1115151</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
        {nav.map(({ label, href }) => (
          <a
            href={href}
            class={`text-sm font-medium transition-colors ${
              currentPath.startsWith(href.replace(/\/$/, ''))
                ? 'text-copper'
                : 'text-slate-300 hover:text-white'
            }`}
          >
            {label}
          </a>
        ))}
        <a
          href="tel:(310) 733-7808"
          class="ml-4 bg-copper hover:bg-copper-light text-white text-sm font-semibold px-5 py-2.5 rounded transition-colors"
        >
          Call Now
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden text-slate-300 hover:text-white p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-navy-800 bg-navy-900"
  >
    <nav class="px-4 py-4 space-y-2" aria-label="Mobile navigation">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class="block text-slate-300 hover:text-white py-2 text-sm font-medium"
        >
          {label}
        </a>
      ))}
      <a
        href="tel:(310) 733-7808"
        class="block mt-4 bg-copper text-white text-sm font-semibold px-5 py-3 rounded text-center"
      >
        Call Now
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
</script>
